MDScreen:
    MDBoxLayout:
        orientation: "vertical"

        MDTopAppBar:
            title: "Gestor Financeiro"
            left_action_items: [["folder-open", lambda x: None]]
            right_action_items: [["content-save", lambda x: None], ["content-save-edit", lambda x: None]]

        MDLabel:
            text: "Projeto base KivyMD pronto para evolucao"
            halign: "center"
